OPENAI_API_KEY=XXXXXX

#tavily
TAVILY_API_KEY=XXXXXX

# Postgres URL for the LangGraph checkpointer. Unset → in-memory saver
# (threads die on restart). For Supabase use the *pooled* connection
# string (port 6543) — free tier has tight direct-connection limits.
# DATABASE_URL=postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# EvolutionAPI — local WhatsApp gateway used by whatsapp_agent.
# Start the service with: docker compose -f docker-compose.evolution.yml up -d
# Pair your number once at http://localhost:8080/manager (scan QR).
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE=estatia

# Outbound WhatsApp outreach toggle. State["whatsapp_enabled"] overrides this
# at runtime when set. Default is off so tests / dev runs never message brokers.
WHATSAPP_ENABLED=false
